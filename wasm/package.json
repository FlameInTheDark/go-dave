    "./wasm_exec.js": "./wasm_exec.js",
    "./package.json": "./package.json"
  },
  "files": [
    "README.md",
    "index.d.ts",
    "index.mjs",
    "go-dave.wasm",
    "wasm_exec.js"
  ],
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "prepack": "node ./scripts/build.mjs"
  },
  "sideEffects": false
}
