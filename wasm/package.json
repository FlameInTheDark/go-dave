{
  "name": "@flameinthedark/go-dave",
  "version": "0.1.0",
  "description": "DAVE session management and WebRTC frame encryption for browser and Electron apps",
  "license": "MIT",
  "type": "module",
  "main": "./index.mjs",
  "module": "./index.mjs",
  "types": "./index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FlameInTheDark/go-dave.git",
    "directory": "wasm"
  },
  "homepage": "https://github.com/FlameInTheDark/go-dave#readme",
  "bugs": {
    "url": "https://github.com/FlameInTheDark/go-dave/issues"
  },
  "publishConfig": {
